datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user") // user, admin
  isActive  Boolean  @default(true)
  lastLogin DateTime?

  // Subscription (Simplified on User)
  subscriptionPlan   String @default("pro") // pro, enterprise
  subscriptionStatus String @default("trial") // active, cancelled, expired, trial, past_due, unpaid
  stripeCustomerId   String?
  trialEndsAt        DateTime?

  // Profile
  company  String?
  website  String?
  industry String?
  phone    String?
  avatar   String?

  // Settings
  emailNotifications Boolean @default(true)
  weeklyReports      Boolean @default(true)
  timezone           String  @default("UTC")

  // API Keys
  openaiKey     String?
  hubspotKey    String?
  salesforceKey String?
  apiKeys       String? // JSON string

  // Usage
  leadsGenerated Int @default(0)
  leadsThisMonth Int @default(0)
  monthlyLimit   Int @default(50)

  // Viral Growth Relations
  referralCode      String   @unique @default(cuid())
  aiCredits         Int      @default(100)
  referredBy        String?
  referrals         Referral[] @relation("ReferrerReferrals")
  referredByUser    Referral?  @relation("ReferredUser")
  creditTransactions CreditTransaction[]
  templates          Template[]
  templatePurchases  TemplatePurchase[]
  templateReviews    TemplateReview[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  subscription Subscription?
  leads        Lead[]
  campaigns    Campaign[]
  workflows    Workflow[]
}

model Subscription {
  id                   String  @id @default(uuid())
  user                 User    @relation(fields: [userId], references: [id])
  userId               String  @unique
  stripeSubscriptionId String? @unique
  stripeCustomerId     String
  plan                 String // pro, enterprise
  status               String  @default("trial") // active, cancelled, expired, trial, past_due, unpaid

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialStart         DateTime?
  trialEnd           DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?

  // Billing
  billingInterval String  @default("month") // month, year
  billingAmount   Int
  billingCurrency String  @default("usd")

  // Features (JSON string)
  features String?

  // Usage
  leadsThisMonth Int @default(0)
  monthlyLimit   Int @default(50)

  metadata String? // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  companyName String
  contactName String?
  email       String?
  phone       String?
  website     String?
  industry    String?
  companySize String?
  location    String?
  linkedinUrl String?
  
  painPoints String? // JSON array string
  salesPitch String?
  
  source   String // ai_generated, manual, import, api
  status   String // new, contacted, qualified, converted, rejected
  priority String // low, medium, high
  
  tags  String? // JSON array string
  notes String?

  // Complex nested objects -> JSON strings
  metadata           String?
  enrichment         String?
  predictive         String?
  competitorInsights String?
  crmData            String?
  outreach           String?

  score       Int     @default(0)
  scoreReason String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  name         String
  status       String   @default("draft") // draft, active, paused, completed
  type         String   @default("email")
  sequenceFlow String? // JSON string
  metrics      String? // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workflow {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  name    String
  trigger String // new_lead, etc.
  nodes   String? // JSON string
  edges   String? // JSON string
  
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id              String   @id @default(cuid())
  referrerId      String
  referrer        User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredEmail   String
  referredUserId  String?  @unique
  referredUser    User?    @relation("ReferredUser", fields: [referredUserId], references: [id])
  status          String   @default("pending") // pending | converted | rewarded
  creditsAwarded  Int      @default(0)
  createdAt       DateTime @default(now())
  convertedAt     DateTime?
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Int      // positive = earned, negative = spent
  type        String   // referral_signup | referral_upgrade | campaign_run | purchased | bonus
  description String
  createdAt   DateTime @default(now())
}

model Template {
  id            String   @id @default(cuid())
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])
  name          String
  description   String
  subjectLine   String
  body          String
  industry      String
  campaignType  String   // cold_outreach | nurture | reengagement | followup
  price         Float    @default(0) // 0 = free
  avgOpenRate   Float?
  useCount      Int      @default(0)
  rating        Float    @default(0)
  ratingCount   Int      @default(0)
  isPublished   Boolean  @default(false)
  isApproved    Boolean  @default(false)
  aiScore       Int?
  tags          String[]
  purchases     TemplatePurchase[]
  reviews       TemplateReview[]
  createdAt     DateTime @default(now())
}

model TemplatePurchase {
  id          String   @id @default(cuid())
  templateId  String
  template    Template @relation(fields: [templateId], references: [id])
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  amountPaid  Float
  createdAt   DateTime @default(now())
}

model TemplateReview {
  id          String   @id @default(cuid())
  templateId  String
  template    Template @relation(fields: [templateId], references: [id])
  reviewerId  String
  reviewer    User     @relation(fields: [reviewerId], references: [id])
  rating      Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())
}
