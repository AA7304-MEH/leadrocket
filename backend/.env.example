# =================================================================
# 🚀 LEAD ROCKETS - PRODUCTION ENVIRONMENT CONFIGURATION
# =================================================================
# Copy this file to .env and fill in your actual values
# See API-KEYS-GUIDE.md for detailed setup instructions

# -----------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-deployed-frontend-domain.com

# -----------------------------------------------------------------
# DATABASE CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------
# MongoDB Atlas Free Tier (512MB storage)
# Get from: https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/leadrockets

# -----------------------------------------------------------------
# JWT CONFIGURATION (REQUIRED - Generate Secure Secrets)
# -----------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-here
JWT_REFRESH_EXPIRE=30d

# -----------------------------------------------------------------
# EMAIL CONFIGURATION (REQUIRED - Gmail Free)
# -----------------------------------------------------------------
# Setup guide: See API-KEYS-GUIDE.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-character-gmail-app-password

# -----------------------------------------------------------------
# PAYMENT CONFIGURATION (Optional - Simulated payments work without)
# -----------------------------------------------------------------
# For real payments, get from: https://stripe.com
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------
# CRM INTEGRATIONS (Optional - Free Tiers Available)
# -----------------------------------------------------------------
# HubSpot (Free: 1,000 contacts) - Get from: https://hubspot.com
HUBSPOT_API_KEY=demo_or_your_hubspot_api_key

# Pipedrive (Free: 300 deals) - Get from: https://pipedrive.com
PIPEDRIVE_API_KEY=demo_or_your_pipedrive_api_key

# Custom CRM Webhook (Optional)
CUSTOM_CRM_WEBHOOK_URL=https://your-crm.com/webhooks/leadrockets

# -----------------------------------------------------------------
# AI ENHANCEMENT (Optional - App works without)
# -----------------------------------------------------------------
# Google AI API (Free: $0/month) - Get from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza_your_google_ai_api_key_here

# OpenAI API (Free: $5 credit) - Get from: https://platform.openai.com
OPENAI_API_KEY=sk_your_openai_api_key_for_enhanced_lead_generation

# -----------------------------------------------------------------
# CACHING & SESSIONS (Optional - App works without)
# -----------------------------------------------------------------
# Redis (Free tiers available) - Get from: https://redis.com
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------
# FILE UPLOAD (Optional)
# -----------------------------------------------------------------
MAX_FILE_SIZE=5242880
FILE_UPLOAD_PATH=./uploads

# -----------------------------------------------------------------
# LOGGING & MONITORING (Optional)
# -----------------------------------------------------------------
# Sentry (Free tier) - Get from: https://sentry.io
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------
# PRODUCTION OPTIMIZATIONS
# -----------------------------------------------------------------
# Enable compression
COMPRESSION_ENABLED=true

# Trust proxy (for Railway/Render deployment)
TRUST_PROXY=true

# Session secret
SESSION_SECRET=your-session-secret-here

# =================================================================
# 🚨 SECURITY NOTES
# =================================================================
# - Never commit .env files to Git
# - Use strong passwords (32+ characters for JWT secrets)
# - Rotate secrets regularly in production
# - Monitor for unauthorized access
# - Keep dependencies updated
# =================================================================