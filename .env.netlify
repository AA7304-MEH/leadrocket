# 🚀 Lead Rockets SaaS - Netlify Environment Variables
# Copy and paste these into your Netlify dashboard: Site Settings → Environment Variables
# ======================================================================================

# ⚠️  IMPORTANT: Replace placeholder values with your actual credentials

# =============================================================================
# 🌐 APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production
FRONTEND_URL=https://your-app-name.netlify.app
PORT=5000

# =============================================================================
# 🔐 AUTHENTICATION (JWT) - MANDATORY
# =============================================================================
# Generate secure JWT secrets (32+ characters each)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-here-minimum-32-characters-replace-this
JWT_REFRESH_SECRET=your-refresh-secret-here-minimum-32-characters-replace-this

# =============================================================================
# 🗄️ DATABASE (MONGODB ATLAS) - MANDATORY
# =============================================================================
# Get from: https://mongodb.com/atlas → Connect → Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/leadrockets

# =============================================================================
# 📧 EMAIL SERVICE (GMAIL SMTP) - MANDATORY
# =============================================================================
# Setup: https://myaccount.google.com/apppasswords
# Enable 2FA first, then generate app password
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-gmail-app-password

# =============================================================================
# 🔗 CRM INTEGRATIONS
# =============================================================================

# HubSpot API (Already configured)
HUBSPOT_API_KEY=6bbd1422-ebc5-4240-813a-a7bfe2d00455

# Pipedrive API (Optional - Free tier available)
# Get from: https://pipedrive.com → Settings → Personal → API
PIPEDRIVE_API_KEY=demo_or_your_pipedrive_api_key

# =============================================================================
# 🤖 AI ENHANCEMENT (Optional - For better performance)
# =============================================================================

# Google AI API (Recommended - Free)
# Get from: https://aistudio.google.com → Get API key
GOOGLE_AI_API_KEY=AIza_your_google_ai_api_key

# OpenAI API (Alternative)
# Get from: https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# 💳 PAYMENT PROCESSING (Optional)
# =============================================================================
# Get from: https://stripe.com → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# 📊 ANALYTICS (Optional)
# =============================================================================
# Google Analytics (if using)
VITE_GA_TRACKING_ID=GA_MEASUREMENT_ID

# =============================================================================
# 🔧 FRONTEND CONFIGURATION
# =============================================================================
VITE_API_URL=https://your-backend-api-url.com

# =============================================================================
# 🚨 SECURITY NOTES
# =============================================================================
# ✅ DO: Use strong, unique secrets for production
# ✅ DO: Set these in Netlify Environment Variables (not in code)
# ✅ DO: Generate new JWT secrets for production
# ❌ DON'T: Commit .env files to Git
# ❌ DON'T: Use weak passwords or demo keys in production

# =============================================================================
# 🎯 MINIMAL REQUIRED VARIABLES (For basic functionality)
# =============================================================================
# Copy these first to get your app running:
# NODE_ENV=production
# FRONTEND_URL=https://your-app-name.netlify.app
# JWT_SECRET=your-32-char-secret-here
# JWT_REFRESH_SECRET=your-32-char-refresh-secret
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/leadrockets
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-gmail-app-password
# HUBSPOT_API_KEY=6bbd1422-ebc5-4240-813a-a7bfe2d00455

# =============================================================================
# 🚀 QUICK SETUP SUMMARY
# =============================================================================
# 1. Copy this entire file content
# 2. Go to Netlify → Site Settings → Environment Variables
# 3. Click "Add variable" for each line (format: KEY=value)
# 4. Replace placeholder values with real credentials
# 5. Deploy and test your application

# Your Lead Rockets SaaS will be live with full functionality! 🎉